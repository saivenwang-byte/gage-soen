PORT=3001
BRAND=介嘎算

# MVP 默认用精选种子数据（含实景图+坐标）；爬虫模式设 DATA_SOURCE=crawl
DATA_SOURCE=curated

# 启用的爬虫（逗号分隔）
ENABLED_SOURCES=meituan,dianping,xiaohongshu,douyin,hema,missfresh,ctrip,lvmama,tujia,bilibili,weibo,eleme

# 代理（大众点评等建议住宅代理）
PROXY_LIST=
PROXY_POOL_URL=

# 验证码打码（可选）
CAPTCHA_API_URL=
CAPTCHA_API_KEY=

# Redis（可选，用于 Bull 队列）
REDIS_URL=

# 商场活动直链
MALL_BAOLONG_URL=
MALL_BAILIAN_URL=

PLAYWRIGHT_HEADLESS=1

# 设为 0 时禁用 liveGenerator 回退，仅真实爬取（需有效 Cookie）
# DEMO_FALLBACK=0

# 可选：从浏览器复制的 Cookie 字符串（推荐仍用 npm run login 写文件）
# DP_COOKIE=
# XHS_COOKIE=

# Cookie 通过 npm run login 写入 data/cookies/*.json，勿提交 Git
