.header {
  padding: 32rpx 28rpx 16rpx;
  background: linear-gradient(135deg, #1a5f4a, #2d8a6e);
  color: #fff;
}
.title { font-size: 40rpx; font-weight: 600; display: block; }
.sub { font-size: 24rpx; opacity: 0.9; margin-top: 8rpx; display: block; }

.card {
  margin: 20rpx 24rpx;
  padding: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.filters .row { margin-bottom: 20rpx; }
.label { font-size: 26rpx; color: #666; display: block; margin-bottom: 8rpx; }
.picker-val, input { font-size: 28rpx; padding: 12rpx 0; }

.tabs { white-space: nowrap; padding: 8rpx 24rpx; }
.tab {
  display: inline-block;
  padding: 12rpx 28rpx;
  margin-right: 12rpx;
  background: #fff;
  border-radius: 999rpx;
  font-size: 26rpx;
}
.tab.active { background: #1a5f4a; color: #fff; }

.sort-bar {
  display: flex;
  gap: 24rpx;
  padding: 0 28rpx 12rpx;
  font-size: 26rpx;
  color: #888;
}
.sort.on { color: #1a5f4a; font-weight: 600; }

.deal-head { display: flex; justify-content: space-between; align-items: flex-start; }
.deal-title { font-size: 30rpx; font-weight: 600; flex: 1; }
.score {
  font-size: 22rpx;
  background: #e8f5ef;
  color: #1a5f4a;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-left: 12rpx;
}
.addr { font-size: 24rpx; color: #888; margin-top: 8rpx; display: block; }
.promo {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #c45c26;
  background: #fff5ee;
  padding: 8rpx 12rpx;
  border-radius: 8rpx;
}
.price-row { margin-top: 16rpx; display: flex; align-items: baseline; gap: 16rpx; }
.per { font-size: 36rpx; color: #c45c26; font-weight: 700; }
.save { font-size: 24rpx; color: #1a5f4a; }
.note { font-size: 22rpx; color: #999; margin-top: 8rpx; display: block; }
.meta { margin-top: 12rpx; font-size: 22rpx; color: #666; }
.tags { margin-left: 12rpx; }

.loading, .error, .empty {
  text-align: center;
  padding: 80rpx 40rpx;
  color: #888;
  font-size: 28rpx;
}
.error { color: #c45c26; }
